{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Docker: Debug",
            "type": "go",
            "request": "attach",
            "mode": "remote",
            "host": "127.0.0.1",
            "port": 2345,
            "remotePath": "/app",
            "preLaunchTask": "docker-compose-dev",
            "postDebugTask": "docker-compose-down"
        },
        {
            "name": "Docker: Attach",
            "type": "go",
            "request": "attach",
            "mode": "remote",
            "host": "127.0.0.1",
            "port": 2345,
            "remotePath": "/app"
        },
        {
            "name": "Local: Debug",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}",
            "env": {
                "CGO_ENABLED": "1"
            },
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}
